  repository: https://github.com/rss-reborn/sol-configs
ksp_version_max: '1.12'
install:
  - file: GameData/Sol-Configs
    install_to: GameData
depends:
  - name: ModuleManager
  - name: Sol-Core
tags:
  - config
  - planet-pack
ksp_version_min: '1.12'