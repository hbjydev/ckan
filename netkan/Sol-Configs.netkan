identifier: Sol-Configs
name: Sol Configs
abstract: The next generation of RSS-Reborn
license: restricted
author:
  - ballisticfox
$kref: '#/ckan/github/RSS-Reborn/Sol-Configs/asset_match/Sol_Configs-.*\.zip'
release_status: stable
resources:
  bugtracker: https://github.com/RSS-Reborn/Sol-Configs/issues
  manual: https://github.com/rss-reborn/sol-configs/wiki
